# 필요한 라이브러리 임포트
import urllib.request  # 웹 API에 요청을 보내기 위한 모듈
import json            # JSON 형식의 데이터를 파싱하기 위한 모듈
import tkinter         # GUI 창을 만들기 위한 모듈
import tkinter.font    # GUI 내부 폰트 설정을 위한 모듈
 
# OpenWeatherMap에서 발급받은 본인의 API Key 입력
API_KEY = "발급받은_자신의_키_입력"
 
# 1분마다 날씨 정보를 갱신하는 함수 정의
def tick1Min():
    # 서울 날씨 데이터를 섭씨 온도(metric) 단위로 요청하는 URL 생성
    url = f"https://api.openweathermap.org/data/2.5/weather?q=Seoul&appid={API_KEY}&units=metric"
   
    # URL을 통해 데이터를 읽어오고 JSON 구조로 변환
    with urllib.request.urlopen(url) as r:
        data = json.loads(r.read())  # 응답 데이터를 파이썬 객체(딕셔너리)로 변환
   
    # 변환된 데이터에서 온도와 습도 값 추출
    temp = data["main"]["temp"]      # 온도 데이터 추출
    humi = data["main"]["humidity"]  # 습도 데이터 추출
   
    # 추출한 정보를 라벨 텍스트로 업데이트 (온도는 소수점 첫째 자리까지 표시)
    label.config(text=f"{temp:.1f}C   {humi}%")
   
    # 60,000ms(1분) 후에 tick1Min 함수를 다시 실행하도록 예약
    window.after(60000, tick1Min)
 
# tkinter 메인 윈도우 창 설정
window = tkinter.Tk()
window.title("TEMP HUMI DISPLAY")  # 창 제목 설정
window.geometry("400x100")          # 창 크기 설정(가로x세로)
window.resizable(False, False)      # 사용자가 창 크기를 조절하지 못하도록 설정
 
# 폰트 스타일 및 크기 설정
font = tkinter.font.Font(size=30)
 
# 날씨 정보를 표시할 라벨 위젯 생성 및 배치
label = tkinter.Label(window, text="", font=font)
label.pack()  # 라벨을 화면 중앙에 배치
 
# 프로그램 시작 시 최초 1회 날씨 정보 호출
tick1Min()
 
# GUI 이벤트 루프 실행 (창이 닫힐 때까지 대기)
window.mainloop()
