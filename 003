from gpiozero import MotionSensor  # GPIO 핀 제어를 통해 PIR 센서를 사용하기 위한 라이브러리
import time                        # 시간 지연(sleep) 기능을 사용하기 위한 모듈
from picamera2 import Picamera2    # 라즈베리 파이 카메라 모듈 v3 이상을 제어하기 위한 라이브러리
import datetime                    # 현재 날짜 및 시간을 가져오기 위한 모듈

# PIR 센서를 GPIO 16번 핀에 연결된 것으로 설정
pirPin = MotionSensor(16)

# 카메라 객체 생성 및 초기 설정
picam2 = Picamera2()
camera_config = picam2.create_preview_configuration() # 카메라 미리보기 설정 생성
picam2.configure(camera_config)                       # 생성된 설정 적용
picam2.start()                                        # 카메라 모듈 가동 시작

try:
    while True:  # 무한 루프를 통해 실시간 감시 상태 유지
        try:
            sensorValue = pirPin.value  # PIR 센서의 현재 값(0 또는 1)을 읽어옴
            
            if sensorValue == 1:        # 센서값이 1(움직임 감지)인 경우 실행
                now = datetime.datetime.now()           # 현재 시스템 시간 취득
                print(now)                              # 터미널에 현재 시간 출력 (로그 확인용)
                
                # 파일명 생성: '년-월-일 시:분:초' 형태의 문자열로 변환
                fileName = now.strftime('%Y-%m-%d %H:%M:%S')
                
                # 생성된 파일명에 '.jpg' 확장자를 붙여 사진 촬영 및 저장
                picam2.capture_file(fileName + '.jpg')
                
                # 중복 촬영 방지 및 센서 안정을 위해 0.5초간 대기
                time.sleep(0.5)
        except:
            # 루프 도중 발생할 수 있는 사소한 에러(센서 읽기 오류 등) 무시하고 계속 진행
            pass

except KeyboardInterrupt:
    # 사용자가 Ctrl+C를 눌러 프로그램을 종료할 때 깔끔하게 루프를 빠져나감
    pass
